# Copy to .env.local and fill values.

NEXTAUTH_SECRET=your-32-char-or-longer-secret
NEXTAUTH_URL=http://localhost:3000

# Google Analytics 4 (browser + optional Measurement Protocol for bot page views)
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4_API_SECRET=your-measurement-protocol-api-secret

# AdSense: optional overrides (layout already loads ca-pub-6090164906593135)
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-6090164906593135
# NEXT_PUBLIC_ADSENSE_ENABLED=1
# NEXT_PUBLIC_AD_STRESS_MODE=0
# NEXT_PUBLIC_ADSENSE_SLOT_TOP=1234567890
# NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM=0987654321

# Static CTA link shown to crawlers / noscript ad fallbacks
# NEXT_PUBLIC_BOT_AD_FALLBACK_URL=https://xpersona.co/for-agents

# Google Ad Manager (agent pages): opt-in; until enabled, /agent/* uses AdSense only and gpt.js is not loaded.
# NEXT_PUBLIC_GAM_AGENT_PAGES_ENABLED=1
# Optional: with GAM on, also show one AdSense unit above GAM slots (transition period)
# NEXT_PUBLIC_GAM_AGENT_PAGES_ADSENSE_ALSO=1
# NEXT_PUBLIC_GAM_NETWORK_CODE=12345678
# NEXT_PUBLIC_GAM_AD_UNIT_AGENT_TOP=/12345678/xpersona/agent-page-top
# NEXT_PUBLIC_GAM_AD_UNIT_AGENT_SIDEBAR=/12345678/xpersona/agent-page-sidebar
# NEXT_PUBLIC_GAM_AD_UNIT_AGENT_BOTTOM=/12345678/xpersona/agent-page-bottom
# GAM_CREATIVE_CACHE_TTL_MS=300000
# GAM_BOT_CREATIVES_JSON=[{"id":"1","slotKey":"agent_top","headline":"Title","description":"Body","clickUrl":"https://example.com","advertiserName":"Brand"}]

# Pay-per-crawl (HTTP 402) for LLM crawlers on premium surfaces (/agent/*, agent snapshot/contract/trust APIs)
# ENABLE_PAY_PER_CRAWL=1
# CRAWL_LICENSE_SECRET=min-16-char-secret-for-hmac-tokens
# CRAWL_LICENSE_TTL_SECONDS=3600
# STRIPE_CRAWL_PRICE_ID_STARTER=price_xxx
# STRIPE_CRAWL_PRICE_ID_GROWTH=price_xxx
# STRIPE_CRAWL_PRICE_ID_SCALE=price_xxx

# VS Code Playground browser auth tokens (recommended in production; falls back to NEXTAUTH_SECRET in dev)
PLAYGROUND_VSCODE_TOKEN_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# HuggingFace Router token for Playground AI chat
# HF_ROUTER_TOKEN=hf_xxx
# Optional backward-compatible aliases:
# HF_TOKEN=hf_xxx
# HUGGINGFACE_TOKEN=hf_xxx

# Playground rollout / kill switches
# PLAYGROUND_ENABLE_TIMELINE=1
# PLAYGROUND_ENABLE_REPLAY=1
# PLAYGROUND_ENABLE_AGENT_ROUNDTABLE=1
# PLAYGROUND_ENABLE_AGGRESSIVE_YOLO=1
# PLAYGROUND_ENABLE_LONG_CONTEXT=1
# PLAYGROUND_LONG_CONTEXT_MODEL=Qwen/Qwen3-32B-Instruct
# PLAYGROUND_INTELLIGENCE_V2=1

# Search crawler (optional but recsommended)
# GITHUB_TOKEN=ghp_xxx
# GitHub App auth (preferred for high-scale workers)
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=12345678
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# High-throughput GitHub settings (recommended for GitHub App auth)
# GITHUB_REQUEST_TIMEOUT_MS=30000
# GITHUB_MAX_RETRIES=4
# GITHUB_MAX_RATE_LIMIT_RETRY_AFTER_S=300
# GITHUB_MAX_BACKOFF_MS=60000
# GITHUB_MIN_SEARCH_INTERVAL_MS=2000
# GITHUB_MIN_CODE_SEARCH_INTERVAL_MS=7000
# ClawHub public API overrides (optional)
# CLAWHUB_API_BASE=https://wry-manatee-359.convex.site
# CLAWHUB_SITE_BASE=https://clawhub.ai
# CLAWHUB_PAGE_LIMIT=200
# CLAWHUB_SORT=downloads
# CLAWHUB_DIR=desc
# CLAWHUB_DETAIL_CONCURRENCY=2
# CLAWHUB_API_MAX_RETRIES=8
# CLAWHUB_API_BASE_BACKOFF_MS=1500
# CLAWHUB_API_MAX_BACKOFF_MS=60000
# CLAWHUB_API_PAGE_DELAY_MS=1000

# Dedicated crawler worker
# CRAWL_WORKER_ID=xpersona-worker-1
# CRAWL_WORKER_HOT_INTERVAL_MS=300000
# CRAWL_WORKER_HOT_MAX_RESULTS=1200
# CRAWL_WORKER_HOT_GITHUB_BUDGET=2000
# CRAWL_WORKER_HOT_TIME_BUDGET_MS=180000
# CRAWL_WORKER_HOT_SOURCES=GITHUB_OPENCLEW,GITHUB_MCP,GITHUB_REPOS,CREWAI,VERCEL_TEMPLATES
# CRAWL_WORKER_BACKFILL_SIZE=250k
# CRAWL_WORKER_BACKFILL_HOUR_UTC=6
# CRAWL_WORKER_BACKFILL_MINUTE_UTC=0
# CRAWL_WORKER_BACKFILL_GITHUB_BUDGET=30000
# CRAWL_WORKER_BACKFILL_TIME_BUDGET_MS=10800000
# CRAWL_WORKER_BACKFILL_SOURCES=
# CRAWL_WORKER_STALE_MS=1800000

# Keep GitHub sources disabled in serverless cron when worker is running
# CRAWL_GITHUB_IN_CRON=0
# CRAWL_DEEP_SAFETY_LIMIT_PER_JOB=100
# CRAWL_MIN_RECRAWL_HOURS=6
# AGENT_FACTS_BACKFILL_BATCH_SIZE=200
# AGENT_FACTS_CRON_LIMIT=3000
# AGENT_FACTS_RECENT_WINDOW_HOURS=48
# AGENT_FACTS_STALE_AFTER_HOURS=168

# Optional distributed rate limiting
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# Search ranking tuning (optional)
# SEARCH_HYBRID_RANKING=1
# SEARCH_RANK_WEIGHT_LEXICAL=0.62
# SEARCH_RANK_WEIGHT_AUTHORITY=0.22
# SEARCH_RANK_WEIGHT_ENGAGEMENT=0.12
# SEARCH_RANK_WEIGHT_FRESHNESS=0.04
# SEARCH_SEMANTIC_ENABLED=1
# SEARCH_EMBEDDING_PROVIDER=openai
# SEARCH_EMBEDDING_MODEL=text-embedding-3-small
# SEARCH_SEMANTIC_CANDIDATES=80
# OPENAI_API_KEY=sk-...
# SEARCH_MEDIA_VERTICAL_ENABLED=1
# SEARCH_MEDIA_SOURCES=GITHUB_REPOS,GITHUB_MCP,GITHUB_OPENCLEW,PYPI,NPM,HUGGINGFACE,REPLICATE,MCP_REGISTRY,CLAWHUB,VERCEL_TEMPLATES,DOCKER
# SEARCH_MEDIA_MIN_QUALITY_SCORE=0
# SEARCH_MEDIA_ALLOWED_HOSTS=raw.githubusercontent.com,github.com,opengraph.githubassets.com,avatars.githubusercontent.com
# SEARCH_MEDIA_DENIED_HOSTS=
# SEARCH_MEDIA_WEB_ENABLED=0

# Admin authorization
ADMIN_EMAILS=suat.bastug@icloud.com,kiraaimoto@gmail.com

# Password reset email (optional)
# RESEND_API_KEY=re_xxx
# EMAIL_FROM="Xpersona <noreply@xpersona.co>"
# SUPPORT_EMAIL="Suat.Bastug@icloud.com"

# Economy / Stripe Connect
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_CONNECT_CLIENT_ID=ca_xxx
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Playground subscriptions (all include a 2-day trial)
# STRIPE_PLAYGROUND_PRICE_ID_STARTER_MONTHLY=price_xxx
# STRIPE_PLAYGROUND_PRICE_ID_STARTER_YEARLY=price_xxx
# STRIPE_PLAYGROUND_PRICE_ID_BUILDER_MONTHLY=price_xxx
# STRIPE_PLAYGROUND_PRICE_ID_BUILDER_YEARLY=price_xxx
# STRIPE_PLAYGROUND_PRICE_ID_STUDIO_MONTHLY=price_xxx
# STRIPE_PLAYGROUND_PRICE_ID_STUDIO_YEARLY=price_xxx
# Legacy fallback (builder monthly only):
# STRIPE_PLAYGROUND_PRICE_ID=price_xxx

# Trust stack
TRUST_RECEIPT_KEYS="dev1:change-me"
TRUST_RECEIPT_ACTIVE_KEY_ID="dev1"
TRUST_HANDSHAKE_TTL_HOURS=168
TRUST_HANDSHAKE_TIMEOUT_MS=6000
TRUST_REPUTATION_WINDOW_DAYS=30
TRUST_INTERNAL_TOKEN=""
TRUST_RECEIPT_ON_OUTCOME=0
TRUST_HANDSHAKE_BATCH=50
TRUST_HANDSHAKE_ONLY_STALE=1
TRUST_REPUTATION_BATCH=100
TRUST_REPUTATION_ONLY_STALE=1
TRUST_REPUTATION_AGENT_IDS=

# GPG (Global Performance Graph)
GPG_SIGNING_KEYS="gpg1:change-me"
GPG_ACTIVE_SIGNING_KEY_ID="gpg1"
GPG_SIGNING_WINDOW_SEC=300
GPG_SIGNING_MAX_SKEW_SEC=300
GPG_CLUSTER_SIM_THRESHOLD=0.86
GPG_BAYES_ALPHA=3
GPG_BAYES_BETA=1
GPG_EXECUTE_BLEND_WEIGHT=0.3
