{
  "name": "xpersona-playground",
  "displayName": "Playground",
  "description": "Minimal AI coding chat in VS Code.",
  "version": "0.0.55",
  "publisher": "playgroundai",
  "license": "UNLICENSED",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri",
    "onView:xpersona.playgroundView",
    "onCommand:xpersona.playground.prompt",
    "onCommand:xpersona.playground.openWithSelection",
    "onCommand:xpersona.playground.setApiKey",
    "onCommand:xpersona.playground.signIn",
    "onCommand:xpersona.playground.signOut",
    "onCommand:xpersona.playground.undoLastChanges"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xpersona",
          "title": "Playground",
          "icon": "media/xpersona.png"
        }
      ]
    },
    "views": {
      "xpersona": [
        {
          "id": "xpersona.playgroundView",
          "name": "Playground",
          "type": "webview",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "xpersona.playground.prompt",
        "title": "New Chat",
        "category": "Playground"
      },
      {
        "command": "xpersona.playground.openWithSelection",
        "title": "Chat with Selection",
        "category": "Playground"
      },
      {
        "command": "xpersona.playground.setApiKey",
        "title": "Set API Key",
        "category": "Playground"
      },
      {
        "command": "xpersona.playground.signIn",
        "title": "Sign In (Browser)",
        "category": "Playground"
      },
      {
        "command": "xpersona.playground.signOut",
        "title": "Sign Out",
        "category": "Playground"
      },
      {
        "command": "xpersona.playground.undoLastChanges",
        "title": "Undo Playground Changes",
        "category": "Playground"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "xpersona.playground.prompt"
        },
        {
          "command": "xpersona.playground.openWithSelection"
        },
        {
          "command": "xpersona.playground.setApiKey"
        },
        {
          "command": "xpersona.playground.signIn"
        },
        {
          "command": "xpersona.playground.signOut"
        },
        {
          "command": "xpersona.playground.undoLastChanges"
        }
      ],
      "editor/context": [
        {
          "command": "xpersona.playground.openWithSelection",
          "group": "2_xpersona@1",
          "when": "editorHasSelection"
        },
        {
          "command": "xpersona.playground.undoLastChanges",
          "group": "2_xpersona@2"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "xpersona.playgroundView",
        "contents": "Minimal coding chat in VS Code.\n[New Chat](command:xpersona.playground.prompt)\n[Chat with Selection](command:xpersona.playground.openWithSelection)\n[Sign In](command:xpersona.playground.signIn)\n[Set API Key](command:xpersona.playground.setApiKey)"
      }
    ],
    "configuration": {
      "title": "Playground",
      "properties": {
        "xpersona.playground.baseApiUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Base URL for the Playground API. Use http://localhost:3000 for local development."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . -w",
    "build": "tsc -p .",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  }
}
