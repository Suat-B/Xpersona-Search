{
  "name": "xpersona-playground",
  "displayName": "Playground",
  "description": "Minimal AI coding chat in VS Code.",
  "version": "0.0.59",
  "publisher": "playgroundai",
  "license": "UNLICENSED",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri",
    "onView:xpersona.playgroundView",
    "onCommand:xpersona.playground.prompt",
    "onCommand:xpersona.playground.openWithSelection",
    "onCommand:xpersona.playground.setApiKey",
    "onCommand:xpersona.playground.signIn",
    "onCommand:xpersona.playground.signOut",
    "onCommand:xpersona.playground.undoLastChanges"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xpersona",
          "title": "Playground",
          "icon": "media/xpersona.png"
        }
      ]
    },
    "views": {
      "xpersona": [
        {
          "id": "xpersona.playgroundView",
          "name": "Playground",
          "type": "webview",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "xpersona.playground.prompt",
        "title": "New Chat",
        "category": "Playground"
      },
      {
        "command": "xpersona.playground.openWithSelection",
        "title": "Chat with Selection",
        "category": "Playground"
      },
      {
        "command": "xpersona.playground.setApiKey",
        "title": "Set API Key",
        "category": "Playground"
      },
      {
        "command": "xpersona.playground.signIn",
        "title": "Sign In (Browser)",
        "category": "Playground"
      },
      {
        "command": "xpersona.playground.signOut",
        "title": "Sign Out",
        "category": "Playground"
      },
      {
        "command": "xpersona.playground.undoLastChanges",
        "title": "Undo Playground Changes",
        "category": "Playground"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "xpersona.playground.prompt"
        },
        {
          "command": "xpersona.playground.openWithSelection"
        },
        {
          "command": "xpersona.playground.setApiKey"
        },
        {
          "command": "xpersona.playground.signIn"
        },
        {
          "command": "xpersona.playground.signOut"
        },
        {
          "command": "xpersona.playground.undoLastChanges"
        }
      ],
      "editor/context": [
        {
          "command": "xpersona.playground.openWithSelection",
          "group": "2_xpersona@1",
          "when": "editorHasSelection"
        },
        {
          "command": "xpersona.playground.undoLastChanges",
          "group": "2_xpersona@2"
        }
      ]
    },
    "configuration": {
      "title": "Playground",
      "properties": {
        "xpersona.playground.baseApiUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Base URL for the Playground API. Use http://localhost:3000 for local development."
        },
        "xpersona.playground.runtime": {
          "type": "string",
          "enum": [
            "playgroundApi",
            "qwenCode"
          ],
          "default": "qwenCode",
          "description": "Choose whether Playground uses the local Qwen Code runtime or the hosted Playground API."
        },
        "xpersona.playground.qwen.model": {
          "type": "string",
          "default": "Qwen/Qwen3-4B-Thinking-2507:nscale",
          "description": "Model name passed to Qwen Code when the runtime is set to qwenCode."
        },
        "xpersona.playground.qwen.baseUrl": {
          "type": "string",
          "default": "http://localhost:3000/api/v1/hf",
          "description": "OpenAI-compatible base URL for Qwen Code. This should be the path prefix before /chat/completions."
        },
        "xpersona.playground.qwen.executable": {
          "type": "string",
          "default": "",
          "description": "Optional path or command for a custom Qwen Code executable. Leave empty to use the SDK-bundled CLI."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . -w",
    "build": "tsc -p .",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@qwen-code/sdk": "^0.1.5"
  }
}


