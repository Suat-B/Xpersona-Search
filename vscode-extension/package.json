{
  "name": "xpersona-playground",
  "displayName": "Xpersona",
  "description": "Chat with AI agents powered by Xpersona — directly in VS Code.",
  "version": "0.0.4",
  "publisher": "xpersona",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:xpersona.playground.prompt",
    "onCommand:xpersona.playground.openWithSelection",
    "onCommand:xpersona.playground.setApiKey",
    "onView:xpersona.playgroundView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xpersona",
          "title": "Xpersona",
          "icon": "media/xpersona.svg"
        }
      ]
    },
    "views": {
      "xpersona": [
        {
          "id": "xpersona.playgroundView",
          "name": "Agent Chat",
          "type": "webview",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "xpersona.playground.prompt",
        "title": "Start Chat with Agent",
        "category": "Xpersona"
      },
      {
        "command": "xpersona.playground.openWithSelection",
        "title": "Chat with Selection",
        "category": "Xpersona"
      },
      {
        "command": "xpersona.playground.setApiKey",
        "title": "Set API Key",
        "category": "Xpersona"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "xpersona.playground.prompt"
        },
        {
          "command": "xpersona.playground.openWithSelection"
        },
        {
          "command": "xpersona.playground.setApiKey"
        }
      ],
      "editor/context": [
        {
          "command": "xpersona.playground.openWithSelection",
          "group": "2_xpersona@1",
          "when": "editorHasSelection"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "xpersona.playgroundView",
        "contents": "Chat with Playground AI — your coding assistant.\n[Start Chat](command:xpersona.playground.prompt)\n[Chat with Selection](command:xpersona.playground.openWithSelection)\n[Set API Key](command:xpersona.playground.setApiKey)"
      }
    ],
    "configuration": {
      "title": "Playground AI",
      "properties": {
        "xpersona.playground.baseApiUrl": {
          "type": "string",
          "default": "https://xpersona.co",
          "description": "Base URL for the Xpersona API. Use http://localhost:3000 for local development."
        },
        "xpersona.playground.model": {
          "type": "string",
          "default": "Qwen/Qwen3-4B-Instruct-2507:nscale",
          "description": "Model identifier for chat completions."
        },
        "xpersona.playground.systemPrompt": {
          "type": "string",
          "default": "You are an expert software engineer and coding assistant. Help the user with their code, answer questions clearly, and provide working examples.",
          "description": "System prompt sent to the AI agent."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . -w",
    "build": "tsc -p .",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  }
}
