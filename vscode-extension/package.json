{
  "name": "xpersona-playground",
  "displayName": "Binary IDE",
  "description": "Binary IDE for generating portable starter bundles from VS Code.",
  "version": "0.0.59",
  "publisher": "playgroundai",
  "license": "UNLICENSED",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri",
    "onView:xpersona.playgroundView",
    "onCommand:binary.generate",
    "onCommand:binary.validate",
    "onCommand:binary.deploy",
    "onCommand:binary.configure",
    "onCommand:xpersona.playground.prompt",
    "onCommand:xpersona.playground.openWithSelection",
    "onCommand:xpersona.playground.setApiKey",
    "onCommand:xpersona.playground.signIn",
    "onCommand:xpersona.playground.signOut",
    "onCommand:xpersona.playground.undoLastChanges"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xpersona",
          "title": "Binary IDE",
          "icon": "media/xpersona.png"
        }
      ]
    },
    "views": {
      "xpersona": [
        {
          "id": "xpersona.playgroundView",
          "name": "Binary IDE",
          "type": "webview",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "binary.generate",
        "title": "Generate Portable Starter Bundle",
        "category": "Binary IDE"
      },
      {
        "command": "binary.validate",
        "title": "Validate Current Portable Bundle",
        "category": "Binary IDE"
      },
      {
        "command": "binary.deploy",
        "title": "Publish Current Portable Bundle",
        "category": "Binary IDE"
      },
      {
        "command": "binary.configure",
        "title": "Configure Binary IDE",
        "category": "Binary IDE"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "binary.generate"
        },
        {
          "command": "binary.validate"
        },
        {
          "command": "binary.deploy"
        },
        {
          "command": "binary.configure"
        }
      ],
      "editor/context": [
        {
          "command": "binary.generate",
          "group": "2_xpersona@1",
          "when": "editorHasSelection"
        },
        {
          "command": "binary.validate",
          "group": "2_xpersona@2"
        }
      ]
    },
    "configuration": {
      "title": "Binary IDE",
      "properties": {
        "xpersona.binary.baseApiUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Base URL for the Binary IDE API. Use http://localhost:3000 for local development."
        },
        "xpersona.binary.runtime": {
          "type": "string",
          "enum": [
            "playgroundApi",
            "qwenCode"
          ],
          "default": "qwenCode",
          "description": "Choose whether Binary IDE uses the local Qwen Code runtime or the hosted Binary IDE API."
        },
        "xpersona.binary.qwen.model": {
          "type": "string",
          "default": "Qwen/Qwen3-Coder-30B-A3B-Instruct:featherless-ai",
          "description": "Model name passed to Qwen Code when the runtime is set to qwenCode."
        },
        "xpersona.binary.qwen.baseUrl": {
          "type": "string",
          "default": "http://localhost:3000/api/v1/hf",
          "description": "OpenAI-compatible base URL for Qwen Code. The default routes through the Binary IDE proxy."
        },
        "xpersona.binary.qwen.executable": {
          "type": "string",
          "default": "",
          "description": "Optional path or command for a custom Qwen Code executable. Leave empty to use the SDK-bundled CLI."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . -w",
    "build": "tsc -p .",
    "package": "vsce package --allow-missing-repository",
    "package:check": "node ./scripts/check-vsix.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@qwen-code/sdk": "^0.1.5"
  }
}


