{
	"name": "cutie-product",
	"displayName": "CUTIE PRODUCT - AI PC Control",
	"description": "Your AI assistant that controls your PC with love!",
	"repository": {
		"type": "git",
		"url": "https://github.com/cutie/product"
	},
	"version": "1.0.3",
	"publisher": "cutie-product",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other",
		"Machine Learning"
	],
	"activationEvents": [
		"onStartupFinished",
		"onUri",
		"onView:cutie-product.chat",
		"onCommand:cutie-product.startChat",
		"onCommand:cutie-product.captureScreen",
		"onCommand:cutie-product.setApiKey",
		"onCommand:cutie-product.signIn",
		"onCommand:cutie-product.signOut",
		"onCommand:cutie-product.stopAutomation"
	],
	"main": "./out/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "cutie-product",
					"title": "CUTIE PRODUCT",
					"icon": "assets/icon.svg"
				}
			]
		},
		"views": {
			"cutie-product": [
				{
					"type": "webview",
					"id": "cutie-product.chat",
					"name": "AI Chat"
				}
			]
		},
		"commands": [
			{
				"command": "cutie-product.startChat",
				"title": "CUTIE: Open AI Chat"
			},
			{
				"command": "cutie-product.captureScreen",
				"title": "CUTIE: Capture Screen"
			},
			{
				"command": "cutie-product.setApiKey",
				"title": "CUTIE: Set Xpersona API Key"
			},
			{
				"command": "cutie-product.signIn",
				"title": "CUTIE: Sign In"
			},
			{
				"command": "cutie-product.signOut",
				"title": "CUTIE: Sign Out"
			},
			{
				"command": "cutie-product.stopAutomation",
				"title": "CUTIE: Stop Automation"
			}
		],
		"configuration": {
			"title": "CUTIE PRODUCT",
			"properties": {
				"cutie-product.baseApiUrl": {
					"type": "string",
					"default": "http://localhost:3000",
					"description": "Base URL for the hosted Xpersona API."
				},
				"cutie-product.model": {
					"type": "string",
					"default": "MiniMaxAI/MiniMax-M2.5:fastest",
					"description": "Model id for the Cutie proxy. Use a \"fastest\" or small variant if your host exposes one—planning runs once per agent step, so a faster model noticeably shortens waits."
				},
				"cutie-product.experimentalDesktopAdapters": {
					"type": "boolean",
					"default": false,
					"description": "Enable experimental desktop automation adapters on macOS and Linux."
				},
				"cutie-product.showDiffToast": {
					"type": "boolean",
					"default": false,
					"description": "Show an information toast when Cutie updates a workspace file (diff may still open depending on auto-open)."
				},
				"cutie-product.autoOpenDiff": {
					"type": "boolean",
					"default": true,
					"description": "Automatically open the diff editor after Cutie edits a file. When off, the before snapshot is still kept for manual diff from chat."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"package": "vsce package"
	},
	"devDependencies": {
		"@types/node": "^20.10.0",
		"@types/vscode": "^1.85.0",
		"typescript": "^5.3.0",
		"@vscode/vsce": "^2.22.0"
	},
	"dependencies": {
		"@xpersona/vscode-core": "file:vendor/xpersona-vscode-core-0.1.0.tgz",
		"screenshot-desktop": "^1.15.0"
	},
	"__metadata": {
		"installedTimestamp": 1766687927550,
		"targetPlatform": "undefined",
		"size": 11058344
	}
}
