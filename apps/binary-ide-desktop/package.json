{
  "name": "@binary-ide/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Binary IDE desktop shell backed by the local Binary Host service.",
  "type": "commonjs",
  "main": "dist/main.js",
  "files": [
    "dist",
    "compat-plugin-overlay.js",
    "renderer",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json && node scripts/copy-renderer.mjs && node scripts/copy-codex-compat-renderer.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "launch": "node scripts/launch-electron.mjs",
    "dev": "npm run build && npm run launch",
    "rebuild:native": "node ./node_modules/@electron/rebuild/lib/cli.js -f -w node-pty",
    "dist": "npm run build && node -e \"console.log('Desktop packaging metadata is ready. Install electron-builder in this package to produce installers.')\""
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "build": {
    "appId": "ai.binary.desktop",
    "productName": "Binary IDE",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "compat-plugin-overlay.js",
      "renderer/**/*"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://downloads.binaryide.ai/releases/${env.BINARY_RELEASE_CHANNEL}"
      }
    ],
    "artifactName": "Binary-IDE-${version}-${os}-${arch}.${ext}",
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Development"
    }
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "@electron/rebuild": "^3.7.1",
    "electron": "^41.1.0"
  }
}
