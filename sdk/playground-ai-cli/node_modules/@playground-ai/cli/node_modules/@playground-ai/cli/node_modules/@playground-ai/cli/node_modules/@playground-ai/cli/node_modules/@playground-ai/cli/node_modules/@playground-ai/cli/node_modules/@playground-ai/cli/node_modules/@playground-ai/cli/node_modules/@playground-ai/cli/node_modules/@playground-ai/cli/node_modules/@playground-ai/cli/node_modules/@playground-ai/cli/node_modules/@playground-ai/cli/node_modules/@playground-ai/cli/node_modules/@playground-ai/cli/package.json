{
  "name": "@binary-ide/cli",
  "version": "0.1.0",
  "description": "Binary IDE CLI - agentic coding runtime for terminal workflows.",
  "type": "module",
  "bin": {
    "binary": "dist/cli.js",
    "binary-ide": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
